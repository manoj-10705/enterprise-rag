# ──────────────────────────────────────────────────────────
# Enterprise RAG Backend — Environment Variables
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control
# ──────────────────────────────────────────────────────────

# Groq API (free at https://console.groq.com)
GROQ_API_KEY=gsk_your_key_here

# Qdrant Vector Database
# Local development: http://localhost:6333
# Qdrant Cloud: https://your-cluster-id.cloud.qdrant.io
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# Collection name for document vectors
COLLECTION_NAME=compliance_documents

# Allowed frontend origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000

# Hugging Face API Token (optional but highly recommended for higher rate limits)
# Get a free token from: https://huggingface.co/settings/tokens
HF_TOKEN=hf_your_token_here

